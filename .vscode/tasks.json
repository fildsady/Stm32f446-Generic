{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build",
            "type": "shell",
            "command": "C:\\Program Files\\Git\\bin\\bash.exe",
            "args": [
                "-c",
                "export PATH=\"/c/Users/${env:USERNAME}/.pico-sdk/python/3.13.7:/c/Users/${env:USERNAME}/make/xpack-windows-build-tools-4.4.1-2/bin:$PATH\" && make"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$gcc",
            "detail": "Build via Git Bash (libopencm3 + FreeRTOS)"
        },
        {
            "label": "Build libopencm3",
            "type": "shell",
            "command": "C:\\Program Files\\Git\\bin\\bash.exe",
            "args": [
                "-c",
                "export PATH=\"/c/Users/${env:USERNAME}/.pico-sdk/python/3.13.7:/c/Users/${env:USERNAME}/make/xpack-windows-build-tools-4.4.1-2/bin:$PATH\" && make -C libopencm3 TARGETS=stm32/f4"
            ],
            "problemMatcher": "$gcc",
            "detail": "Build libopencm3 library only"
        },
        {
            "label": "Clean",
            "type": "shell",
            "command": "C:\\Program Files\\Git\\bin\\bash.exe",
            "args": [
                "-c",
                "export PATH=\"/c/Users/${env:USERNAME}/.pico-sdk/python/3.13.7:/c/Users/${env:USERNAME}/make/xpack-windows-build-tools-4.4.1-2/bin:$PATH\" && make clean"
            ],
            "problemMatcher": [],
            "detail": "Clean build artifacts"
        }
    ]
}
