[submodule "FreeRTOS-Kernel"]
	path = FreeRTOS-Kernel
	url = https://github.com/FreeRTOS/FreeRTOS-Kernel.git
[submodule "Drivers/CMSIS/Core"]
	path = Drivers/CMSIS/Core
	url = https://github.com/STMicroelectronics/cmsis_core.git
[submodule "Drivers/CMSIS/Device/ST/STM32F4xx"]
	path = Drivers/CMSIS/Device/ST/STM32F4xx
	url = https://github.com/STMicroelectronics/cmsis_device_f4.git
[submodule "Drivers/STM32F4xx_HAL_Driver"]
	path = Drivers/STM32F4xx_HAL_Driver
	url = https://github.com/STMicroelectronics/stm32f4xx_hal_driver.git
[submodule "Drivers/CMSIS-DSP"]
	path = Drivers/CMSIS-DSP
	url = https://github.com/ARM-software/CMSIS-DSP.git
